title <b>Backend — System Component Architecture</b>\n<size:11>FastAPI · MongoDB · Firestore · Milvus · Gemini · SarvamAI</size>

'-------- CLIENT ---------
package "Clients" as Clients #EAF4FB {
  [Mobile / Web App] as MobileApp
  [IoT Device\n(Voice)] as Device
}

'-------- API GATEWAY LAYER --------
package "FastAPI Application  /api/v1" as FastAPI #FFF9E6 {

  package "Routers (HTTP boundary)" as Routers #FFFDE7 {
    [auth.py\nPOST /auth/register\nPOST /auth/login\nPOST /auth/google] as AuthRouter
    [user.py\nGET|PATCH|DELETE /user/me] as UserRouter
    [conversation.py\nCRUD /conversations] as ConvRouter
    [message.py\nPOST|GET /messages] as MsgRouter
    [agent.py\nPOST /agent/query\nPOST /agent/device-voice-assistant] as AgentRouter
    [device.py\nPOST /devices/online/:id\nPOST /devices/heartbeat/:id\nGET /devices/mine\nGET|PATCH /devices/config\nGET /devices/:id/status\nPOST /devices/:id/unpair\nGET /devices/:id/history\nGET /devices/firmware/download\n<size:10>in-memory rate-limit: 5 req / 60 s</size>] as DeviceRouter
    [notification.py\nGET /notifications\nDELETE /notifications/:id] as NotifRouter
    [mqtt.py\nPOST /mqtt/publish] as MqttRouter
  }

  package "Legacy Endpoints (main.py)" as LegacyEndpoints #FFF3E0 {
    [POST /raw-voice-assistant\nPOST /voice-assistant\nGET /test-audio-generator\nGET /testing-audio-stream] as LegacyRoutes
  }

  package "Utility / Security" as UtilPkg #F1F8E9 {
    [security.py\nJWT create/decode\nbcrypt · get_current_user()] as Security
    [firebase_init.py\nFirebase Admin SDK\nverify_firebase_token()] as FirebaseUtil
  }

  package "Controllers (Business Logic)" as Controllers #E8F5E9 {
    [AuthController\nregister · login · google_auth] as AuthCtrl
    [UserController\nget · update · delete profile] as UserCtrl
    [ConversationController\nCRUD conversations + sessions] as ConvCtrl
    [MessageController\nappend · fetch messages in session] as MsgCtrl
    [DeviceConfigController\nget/upsert device learning config] as DevCtrl
    [DeviceController\nupsert config · notify transfer\nrelease on account deletion] as DeviceCtrl
    [NotificationController\npaginated fetch · ownership delete] as NotifCtrl
  }

  package "Agent Layer" as AgentLayer #EDE7F6 {
    [core_agent.py\nLangGraph StateGraph\nrun_agent()] as CoreAgent
    [agent_memory_controller.py\nchat history (last 2 msgs)\ndevice_session_id] as MemCtrl
    [llm.py\nGemini 2.0 flash-lite\nChatGoogleGenerativeAI] as LLM
    [prompts.py\n9 agent + 2 legacy prompts] as Prompts
    [schemas.py\nTool-call Pydantic schemas\nQueryClassification · LessonPlan\nEvaluation · TopicAnalysis\n(intent: answer|clarification|new_topic\n off_topic|small_talk|repeat)] as Schemas
    [utility.py\nSarvamAI TTS pipeline\nsentence_pipelined_tts()\ntts_sentence() · split_into_sentences()\ngenerate_filler_audio()\ntranslate_text() · chunk_text()] as AgentUtil
  }
}

'-------- DATA LAYER --------
package "Data Layer" as DataLayer #FBE9E7 {

  package "MongoDB Atlas  (neurosattva)" as MongoDB #FFEBE6 {
    database "users" as UsersCol
    database "conversations" as ConvCol
    database "sessions\n(messages + agent checkpoints)" as SessionsCol
    database "devices\n(ownership ledger)" as DevicesCol
    database "device_config" as DevConfigCol
    database "notifications" as NotifCol
    database "messages\n(future use)" as MsgsCol
    database "firmware\n(OTA versions)" as FirmwareCol
  }

  package "Google Cloud Firestore" as Firestore #FCE4EC {
    database "student_metrics\n(quiz analytics)" as MetricsCol
  }

  package "Milvus Vector DB" as MilvusDB #E8EAF6 {
    database "educational_content\n(768-dim COSINE)" as VectorCol
  }
}

'-------- EXTERNAL SERVICES --------
package "External Services" as External #F3E5F5 {
  [Google Gemini 2.0\nflash-lite\n(LLM inference)] as Gemini
  [Google GenAI\ngemini-embedding-001\n(768-dim embeddings)] as EmbedAPI
  [SarvamAI\nSTT: saaras:v2.5\nTTS: bulbul:v2\nTranslate: sarvam-translate:v1] as Sarvam
  [Firebase Auth\n(Google Sign-In token\nverification)] as FirebaseAuth
  [Google Cloud Storage\nbucket: vijayebhav-firmware\n(firmware .bin files)] as GCS
  [HiveMQ Cloud\nMQTT Broker\n(device commands)] as HiveMQ
}

'-------- RELATIONSHIPS --------

' Clients → Routers
MobileApp --> AuthRouter : HTTPS REST
MobileApp --> UserRouter
MobileApp --> ConvRouter
MobileApp --> MsgRouter
MobileApp --> AgentRouter : text query
MobileApp --> DeviceRouter
MobileApp --> NotifRouter
MobileApp --> MqttRouter
Device --> AgentRouter : raw WAV
Device --> LegacyRoutes : raw WAV (legacy)

' Router → Security
AuthRouter ..> Security : get_current_user()
UserRouter ..> Security
ConvRouter ..> Security
MsgRouter ..> Security
AgentRouter ..> Security
DeviceRouter ..> Security : (heartbeat/online/status/unpair/history/config)
NotifRouter ..> Security
MqttRouter ..> Security

' Router → Controller
AuthRouter --> AuthCtrl
UserRouter --> UserCtrl
ConvRouter --> ConvCtrl
MsgRouter --> MsgCtrl
AgentRouter --> CoreAgent
DeviceRouter --> DevCtrl
DeviceRouter --> DeviceCtrl
DeviceRouter --> FirmwareCol : latest version lookup
DeviceRouter --> GCS : download firmware .bin
NotifRouter --> NotifCtrl
MqttRouter --> HiveMQ : publish(topic, message, qos=0)

' Auth → Firebase util
AuthCtrl --> FirebaseUtil : google_auth flow

' Controllers → DB
AuthCtrl --> UsersCol
UserCtrl --> UsersCol
ConvCtrl --> ConvCol
ConvCtrl --> SessionsCol
MsgCtrl --> SessionsCol
DevCtrl --> DevConfigCol
DeviceCtrl --> DevicesCol
DeviceCtrl --> DevConfigCol : ownership change
DeviceCtrl --> NotifCol : transfer notification
DeviceCtrl --> HiveMQ : unpair cmd\n(devices/:id/commands, qos=1)
NotifCtrl --> NotifCol

' Security → DB
Security --> UsersCol : lookup user by id

' Agent internal wiring
CoreAgent --> LLM
CoreAgent --> MemCtrl
CoreAgent --> Prompts
CoreAgent --> Schemas
CoreAgent --> AgentUtil
MemCtrl --> SessionsCol : chat history\n+ checkpoints

' Agent → DB / Vector
CoreAgent --> SessionsCol : MongoDBSaver\ncheckpoint
' NOTE: VectorDB (Milvus) integration exists in vector_db.py but is currently DEACTIVATED
'       get_similar_documents() is commented out — no vector search in current agent.
' CoreAgent ..> VectorCol : get_similar_documents()  [INACTIVE]

' Legacy endpoints wiring
' NOTE: In main.py legacy routes — STT + Gemini LLM calls are commented out.
' Only GET /test-audio-generator (TTS via SarvamAI) is fully active.
LegacyRoutes --> Sarvam : TTS (active) / STT+LLM inactive
' LegacyRoutes --> Gemini : LLM (legacy prompts)  [INACTIVE — commented out]

' External service calls
LLM --> Gemini : inference
' VectorCol ..> EmbedAPI : embed query  [INACTIVE — vector search deactivated]
AgentUtil --> Sarvam : TTS streaming
AgentRouter --> Sarvam : STT (WAV → text)
FirebaseUtil --> FirebaseAuth : verify_id_token()
Firestore ..> MetricsCol

